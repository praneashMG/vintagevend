    <style>
        /* =========================
           THEME VARIABLES – VINTAGE RED
        ========================= */
        :root, html[data-theme='light'] {
            --color-background: #FDF8F5;
            --color-primary-text: #2C1810;
            --color-secondary-text: #5A3A2A;
            --color-accent: #C0392B;
            --color-primary: #9B2C1D;
            --color-secondary: #E67E22;
            --color-border: #EAD7C3;
            --color-hover: #FCE4D6;
            --color-footer-bg: #2C1810;
            --color-footer-text: #FDF2E9;
            --color-card-bg: #FFFFFF;
        }
        html[data-theme='dark'] {
            --color-background: #1E1410;
            --color-primary-text: #FCE4D6;
            --color-secondary-text: #EAD7C3;
            --color-accent: #E74C3C;
            --color-primary: #C0392B;
            --color-secondary: #E67E22;
            --color-border: #4A2A1A;
            --color-hover: #3A2218;
            --color-footer-bg: #0A0604;
            --color-footer-text: #FCE4D6;
            --color-card-bg: #2A1A12;
        }
        
        body {
            background: var(--color-background);
            color: var(--color-primary-text);
            font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            transition: background-color 0.3s, color 0.3s;
            overflow-x: hidden;
        }
        
        .text-primary-text { color: var(--color-primary-text); }
        .text-secondary-text { color: var(--color-secondary-text); }
        .text-accent { color: var(--color-accent); }
        .text-primary { color: var(--color-primary); }
        .text-secondary { color: var(--color-secondary); }
        .bg-background { background-color: var(--color-background); }
        .bg-hover { background-color: var(--color-hover); }
        .border-border { border-color: var(--color-border); }
        
        /* =========================
           NAVBAR
        ========================= */
        #main-header nav {
            background: var(--color-card-bg);
            border-radius: 9999px;
            padding: 10px 25px;
            margin: 0 auto;
            max-width: 1200px;
            box-shadow: 0 10px 25px rgba(156, 44, 29, 0.15);
        }
        
        .header-accent { color: var(--color-primary); }
        
        .nav-link {
            position: relative;
            transition: color 0.3s;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            bottom: 0;
            height: 2px;
            background-color: var(--color-accent);
            transform: scaleX(0);
            transition: transform 0.3s;
        }
        .nav-link:hover::after, .nav-link.active::after { transform: scaleX(1); }
        
        /* Dropdowns */
        .dropdown-wrapper { position: relative; }
        .dropdown-menu {
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            background-color: var(--color-card-bg);
            border: 1px solid var(--color-border);
            border-radius: 0.5rem;
            box-shadow: 0 12px 30px rgba(156, 44, 29, 0.18);
            min-width: 200px;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: 0.25s ease;
        }
        .dropdown-wrapper.open .dropdown-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
        .dropdown-wrapper.open svg { transform: rotate(180deg); transition: 0.25s; }
        .dropdown-menu a, .dropdown-menu button {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1rem;
            color: var(--color-primary-text);
            text-decoration: none;
            font-size: 0.875rem;
            transition: all 0.2s ease;
            border-bottom: 1px solid var(--color-border);
            width: 100%;
            background: none;
            cursor: pointer;
        }
        .dropdown-menu a:last-child, .dropdown-menu button:last-child { border-bottom: none; }
        .dropdown-menu a:hover, .dropdown-menu button:hover {
            background-color: var(--color-hover);
            color: var(--color-accent);
            padding-left: 1.25rem;
        }
        
        @media (max-width: 1024px) {
            .dropdown-menu {
                position: absolute;
                top: calc(100% + 8px);
                left: 0;
                display: none;
                opacity: 0;
                visibility: hidden;
            }
            .dropdown-wrapper.open .dropdown-menu { display: block; opacity: 1; visibility: visible; transform: translateY(0); }
        }
        
        /* GLOW & CARDS */
        .glow-effect { box-shadow: 0 0 20px rgba(192, 57, 43, 0.1); }
        .glow-on-hover:hover { box-shadow: 0 0 25px rgba(192, 57, 43, 0.3); }
        
        /* Marquee */
        .testimonial-marquee { width: 100%; overflow: hidden; position: relative; }
        .marquee-track { display: flex; width: max-content; animation: marqueeScroll 30s linear infinite; }
        .testimonial-card { flex: 0 0 auto; margin-right: 24px; background: var(--color-card-bg); border-radius: 1rem; width: 320px; }
        @keyframes marqueeScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
        .testimonial-marquee:hover .marquee-track { animation-play-state: paused; }
        
        /* Circles */
        .circle-card {
            width: 180px;
            height: 180px;
            background: var(--color-card-bg);
            border-radius: 50%;
            border: 3px solid var(--color-border);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: .4s ease;
            margin: auto;
        }
        .circle-card:hover { transform: scale(1.08); box-shadow: 0 0 25px rgba(192,57,43,0.4); border-color: var(--color-accent); }
        .circle-inner h3 { font-size: 2.5rem; font-weight: bold; color: var(--color-accent); }
        
        /* Project overlay */
        .project-card { position: relative; overflow: hidden; border-radius: 1rem; transition: all 0.4s ease; background: var(--color-card-bg); }
        .project-overlay {
            position: absolute; inset: 0; background: linear-gradient(to top, rgba(156, 44, 29, 0.9), transparent);
            opacity: 0; transition: opacity 0.4s ease; display: flex; flex-direction: column; justify-content: flex-end; padding: 1.5rem;
        }
        .project-card:hover .project-overlay { opacity: 1; }
        .project-card:hover { transform: scale(1.03); }
        
        /* Articles */
        .article-card { transition: all 0.3s ease; background: var(--color-card-bg); border: 1px solid var(--color-border); border-radius: 1rem; overflow: hidden; }
        .article-card:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(156,44,29,0.12); }
        .article-image { height: 200px; width: 100%; object-fit: cover; transition: transform 0.6s ease; }
        .article-card:hover .article-image { transform: scale(1.05); }
        
        .gradient-text {
            background: linear-gradient(90deg, var(--color-primary), var(--color-accent), var(--color-secondary));
            -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
            display: inline-block;
        }
        
        .btn-primary { background-color: var(--color-primary); color: white; transition: all 0.3s; }
        .btn-primary:hover { background-color: var(--color-accent); box-shadow: 0 0 20px rgba(192,57,43,0.4); }
        .btn-accent { background-color: var(--color-accent); color: white; transition: all 0.3s; }
        .btn-accent:hover { background-color: var(--color-secondary); box-shadow: 0 0 20px rgba(230,126,34,0.4); }
        
        .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s ease; }
        .reveal.active { opacity: 1; transform: translateY(0); }
        
        .particle-bg { position: absolute; top:0; left:0; width:100%; height:100%; overflow:hidden; z-index:0; }
        .particle { position: absolute; background-color: var(--color-accent); border-radius: 50%; opacity: 0.15; animation: floatParticle 12s infinite ease-in-out; }
        @keyframes floatParticle { 0%,100% { transform: translateY(0) translateX(0); } 50% { transform: translateY(-20px) translateX(10px); } }
        
        .footer-link { color: #ffffff; transition: color 0.3s; }
        .footer-link:hover { color: var(--color-accent); }

        @media (max-width: 768px) {
            .circle-card { width: 140px; height: 140px; }
            .circle-inner h3 { font-size: 2rem; }
            .circle-cards-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 20px !important; }
            .project-overlay { opacity: 1 !important; background: linear-gradient(to top, rgba(156,44,29,0.85), rgba(156,44,29,0.4), transparent); }
        }
        @media (max-width: 1280px) {
            .circle-cards-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 24px !important; justify-items: center; }
        }
    </style>
